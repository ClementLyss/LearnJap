generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (Auth.js) ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  progress      UserProgress[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Kanji ───────────────────────────────────────────────────────

model Kanji {
  id          Int       @id @default(autoincrement())
  character   String    @unique
  jlptLevel   Int
  grade       Int?
  strokeCount Int
  strokeOrder Json?     // Ordered array of SVG paths (KanjiVG data)
  meaningFr   String
  meaningEn   String?
  radicals    KanjiRadical[]
  readings    KanjiReading[]
  examples    KanjiExample[]
  progress    UserProgress[]

  @@index([jlptLevel])
}

model Radical {
  id          Int       @id @default(autoincrement())
  character   String    @unique
  meaningFr   String
  meaningEn   String?
  strokeCount Int
  kanjis      KanjiRadical[]
}

model KanjiRadical {
  id        Int     @id @default(autoincrement())
  kanjiId   Int
  kanji     Kanji   @relation(fields: [kanjiId], references: [id], onDelete: Cascade)
  radicalId Int
  radical   Radical @relation(fields: [radicalId], references: [id], onDelete: Cascade)

  @@unique([kanjiId, radicalId])
}

model KanjiReading {
  id      Int    @id @default(autoincrement())
  kanjiId Int
  kanji   Kanji  @relation(fields: [kanjiId], references: [id], onDelete: Cascade)
  type    String // "on" | "kun"
  reading String // しょく / た.べる
  romaji  String // shoku / taberu
}

model KanjiExample {
  id         Int     @id @default(autoincrement())
  kanjiId    Int
  kanji      Kanji   @relation(fields: [kanjiId], references: [id], onDelete: Cascade)
  word       String  // 食べる
  reading    String  // たべる
  meaningFr  String  // "manger"
  sentence   String? // 毎日ご飯を食べる
  sentenceFr String? // "Je mange du riz tous les jours"
}

// ─── Vocabulary ──────────────────────────────────────────────────

model VocabularyItem {
  id        Int       @id @default(autoincrement())
  word      String
  reading   String
  meaningFr String
  category  String
  jlptLevel Int?
  progress  UserProgress[]

  @@index([category])
  @@index([jlptLevel])
}

// ─── User Progress (SM-2 Spaced Repetition) ──────────────────────

model UserProgress {
  id          Int       @id @default(autoincrement())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kanjiId     Int?
  kanji       Kanji?    @relation(fields: [kanjiId], references: [id], onDelete: Cascade)
  vocabId     Int?
  vocab       VocabularyItem? @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  // SM-2 algorithm fields
  repetitions  Int      @default(0)
  easeFactor   Float    @default(2.5)
  interval     Int      @default(0)    // days
  score        Int      @default(0)
  attempts     Int      @default(0)
  lastReviewed DateTime?
  nextReview   DateTime?

  createdAt    DateTime @default(now())

  @@unique([userId, kanjiId])
  @@unique([userId, vocabId])
}
